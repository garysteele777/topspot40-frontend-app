{
  "name": "topspot-frontend-app",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "dev:local": "cross-env VITE_API_BASE_URL=http://127.0.0.1:8000 VITE_PLAYBACK_POLL_MS=250 vite dev",
    "dev:render": "cross-env VITE_API_BASE_URL=https://api.topspot40.com VITE_PLAYBACK_POLL_MS=500 vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
  },
  "devDependencies": {
    "@sveltejs/adapter-auto": "^7.0.0",
    "@sveltejs/adapter-netlify": "^6.0.4",
    "@sveltejs/kit": "^2.49.1",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "cross-env": "^10.1.0",
    "svelte": "^5.45.6",
    "svelte-check": "^4.3.4",
    "typescript": "^5.9.3",
    "vite": "^7.2.6"
  }
}
